# Server-side only — these NEVER reach the browser. Set them in your host's
# environment (e.g. Vercel Project Settings), and in a local .env.local only if you
# point local dev at a real database. The default `npm run dev` uses an in-process
# seeded database and needs just APP_PASSWORD.
#
# Do NOT commit real values — this repo is public.

# Neon Postgres connection string (full-privilege). Browser never sees this.
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# The single dashboard user's password. Checked constant-time on /api/login.
APP_PASSWORD=change-me

# Optional: explicit session-cookie signing key. If unset, it is derived from
# APP_PASSWORD, so the required surface stays DATABASE_URL + APP_PASSWORD. Set a
# long random value to manage/rotate sessions independently of the password.
# SESSION_SECRET=long-random-string
