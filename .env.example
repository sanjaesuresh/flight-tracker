# flight-tracker poller secrets.
# Copy this file to `.env` and fill in the values. NEVER commit `.env` — it is
# gitignored; only this `.example` template is public. The same values also go
# into GitHub Actions secrets later (Task 11), never into logs.

# --- Database: Neon (free-tier Postgres) --------------------------------------
# Create a free project at https://neon.tech (sign in with GitHub, no card).
# Then: project Dashboard -> Connect -> copy the connection string.
# Use the DIRECT connection string (not the pooled -pooler one) for this short-lived
# hourly batch job. It must include ?sslmode=require (Neon requires TLS).
# Format: postgresql://<user>:<password>@ep-xxxx.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# --- Gmail SMTP (alert sender) ------------------------------------------------
# The Gmail address that SENDS the alert emails (can be your own account).
GMAIL_ADDRESS=

# A Gmail APP PASSWORD (requires 2-Step Verification on the account):
#   Google Account -> Security -> 2-Step Verification -> App passwords.
# This is NOT your normal Gmail login password.
GMAIL_APP_PASSWORD=
